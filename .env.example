ASSISTANT_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional when ASSISTANT_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

NEXT_PUBLIC_SHOW_ASSISTANT_PROVIDER=false

# Form email delivery (required for /api/forms/contact and /api/forms/lead)
RESEND_API_KEY=

# Internal inbox receiving all form submissions
FORM_MAIL_TO=khuongbinh.info@gmail.com

# Required on Cloudflare/production; local dev falls back to onboarding@resend.dev
FORM_MAIL_FROM=

# Optional base URL for images in form emails
# Example: https://www.truyendongcongnghiep.top
FORM_ASSET_BASE_URL=

# Optional external Studio URL for Cloudflare production
# Example: https://studio.your-domain.com or https://your-project.sanity.studio
STUDIO_EXTERNAL_URL=
